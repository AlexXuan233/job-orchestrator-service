# Sample env config — copy to .env and edit as needed.
# Your service loads these via env var (not hardcode!).

# --- HTTP server ---
HTTP_PORT=8080
HTTP_READ_TIMEOUT_MS=5000
HTTP_WRITE_TIMEOUT_MS=10000
HTTP_SHUTDOWN_TIMEOUT_MS=20000

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_DIAL_TIMEOUT_MS=1000

# --- Worker pool ---
WORKER_COUNT=10
WORKER_ATTEMPT_TIMEOUT_MS=10000
WORKER_JOB_TIMEOUT_MS=30000
WORKER_RETRY_MAX=3
WORKER_RETRY_BASE_MS=200
WORKER_RETRY_MAX_MS=5000

# --- Dedup ---
DEDUP_WINDOW_SECONDS=60

# --- Per-domain rate limit ---
PER_DOMAIN_MAX_INFLIGHT=5

# --- Observability ---
LOG_LEVEL=info
LOG_FORMAT=json
METRICS_PATH=/metrics
